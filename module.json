{
  "manifestVersion": 1,
  "key": "marketplace",
  "name": "Module Marketplace",
  "version": "0.1.5",
  "description": "Discover, inspect, and manage trusted SkaiCloud module packages through the metadata-first review workflow.",
  "compatibility": {
    "minimumBuild": 6000,
    "moduleApiVersion": 1
  },
  "navigation": {
    "label": "Module Marketplace",
    "path": "/dashboard/marketplace",
    "category": "administration",
    "icon": "briefcase",
    "showInNavigation": true
  },
  "permissions": {
    "accessKey": "marketplace",
    "enabledByDefault": false,
    "masterOnly": false
  },
  "data": {
    "prismaModels": [],
    "sqliteTables": [],
    "appSettingsKeys": [],
    "uploadPaths": []
  },
  "capabilities": {
    "csvExport": false,
    "csvImport": false,
    "completeBackup": false,
    "moduleRestore": false
  },
  "dependencies": {
    "moduleKeys": []
  },
  "package": {
    "routeEntry": "package/routes/marketplace.ts",
    "componentEntry": "package/components/Marketplace.tsx",
    "backupStrategy": "none",
    "rollbackStrategy": "disable-only",
    "requiredEnv": [],
    "postInstallChecks": [
      "Open /dashboard/marketplace",
      "Confirm the Command connection indicator reports catalog connectivity",
      "Confirm search and category filters update the catalog",
      "Confirm package review actions do not execute uploaded code",
      "Confirm the module can be disabled without deleting data"
    ],
    "healthChecks": [
      {
        "key": "dashboard",
        "type": "dashboard-route"
      },
      {
        "key": "runtime-script",
        "type": "runtime-asset",
        "path": "package/web/app.js"
      }
    ],
    "publisher": "SkaiCloud Network LLC",
    "checksum": "sha256:3f4e65a5037881961b70e000d8f0f18c21b3101267a82ba1bcc975bc996b956d",
    "signature": "package/SIGNATURE.txt",
    "runtime": {
      "mode": "sandboxed-iframe",
      "dashboardEntry": "package/web/dashboard.html",
      "dataResources": []
    }
  }
}
